# XTREAM Codes credentials
XTREAM_URL=http://your-provider.com:8080
XTREAM_USERNAME=your_username
XTREAM_PASSWORD=your_password

# Path on the HOST where .strm files will be written (mounted into container)
# This should match your Jellyfin / Kodi library source folder
LIBRARY_PATH=/mnt/media/shows

# Path on the HOST where movie .strm files will be written.
# Should match your Jellyfin / Kodi Movies library source folder.
LIBRARY_PATH_MOVIES=/mnt/media/movies

# Trakt API — create an app at https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
# Set this to the address your browser can reach this app on
TRAKT_REDIRECT_URI=http://localhost:8000/trakt/callback

# Nightly job (failover check + catalog refresh + .strm sync)
# Defaults: 03:00 Europe/Paris, enabled. Override per host as needed.
# SYNC_CRON_HOUR=3
# SYNC_CRON_MINUTE=0
# SYNC_CRON_TIMEZONE=Europe/Paris
# SYNC_CRON_ENABLED=true
# STRM_AUDIT_SAMPLE=10

# Provider URL list file (CURRENT / BURNED format)
# PROVIDERS_FILE=/data/URL.md

# Discord webhook for failover / audit / error notifications.
# Leave empty to disable.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Mirror endpoint — clients (Dispatcharr, TiviMate, Jellyfin) point here.
# .strm files and rewritten m3u playlists embed this URL, so it has to be
# reachable from wherever your clients live (LAN IP, Tailscale, NPM hostname).
# Set to empty string to disable the mirror and embed direct upstream URLs.
MIRROR_PUBLIC_URL=http://YOUR_SERVER_IP:8011
MIRROR_USERNAME=mirror
MIRROR_PASSWORD=mirror

# TMDB v3 API key (https://www.themoviedb.org/settings/api). Used by Phase 2b
# movie enrichment + collections. Empty disables enrichment.
TMDB_API_KEY=

# Radarr — used by Phase 2b "Request" button on unavailable collection films.
# Leave RADARR_URL empty to hide Request buttons.
RADARR_URL=http://YOUR_RADARR_IP:7878
RADARR_API_KEY=
RADARR_ROOT_FOLDER=/media/WD4_Films
RADARR_QUALITY_PROFILE_ID=1

# Phase 3 — movie language filter (browse-side only; the mirror endpoint is
# already gated on in_library so curated picks always pass through).
# Comma-separated ISO 639-1 codes. Use `multi` to also surface entries the
# provider tags as multi-audio.
ALLOWED_LANGUAGES=fr,en
# Surface entries with no recognisable language prefix (TOP -, AMAZON MOVIES…).
ALLOW_LANGUAGE_UNKNOWN=false
# Surface entries where the prefix is a subtitle marker (FR - VOSTFR,
# MULTI-SUBS). Audio is the original language; only the subs are ours.
ALLOW_LANGUAGE_SUBS_ONLY=false
# Master switch. Set false to browse the unfiltered catalog.
LANGUAGE_FILTER_ENABLED=true

# Streaming proxy — when true, stream requests are proxied through a local
# FFmpeg remux instead of returning a 302 redirect to the upstream. This
# normalises MKV timestamps (fixes subtitle lag) and prevents Jellyfin's
# ffprobe from chasing multi-hop redirects (prevents stuck HLS sessions).
# Requires ffmpeg in the container (included in the image by default).
# PROXY_STREAMS=false

# Jellyfin watchdog — detects and auto-heals XTREAM sessions stuck at
# position 0 (null MediaStreams cache from a failed ffprobe). Requires a
# Jellyfin API key: Dashboard → API Keys → +
# JELLYFIN_URL=http://YOUR_SERVER_IP:8096
# JELLYFIN_API_KEY=
# JELLYFIN_WATCHDOG_ENABLED=true
# JELLYFIN_WATCHDOG_INTERVAL_MINUTES=2   # how often to sweep
# JELLYFIN_STUCK_THRESHOLD_SECONDS=45    # kill if stuck longer than this

# EPGenius — auto-update your EPGenius playlist when the XTREAM provider URL
# changes (failover). Get your API key and Discord ID from the EPGenius bot.
# EPGENIUS_ENABLED=true
# EPGENIUS_API_KEY=
# EPGENIUS_DISCORD_ID=
# EPGENIUS_PLAYLIST_ID=    # Playlist Key from /info bot command (integer)
# EPGENIUS_M3U_URL=https://drive.usercontent.google.com/download?id=YOUR_GOOGLE_DRIVE_FILE_ID&export=download&confirm=t
